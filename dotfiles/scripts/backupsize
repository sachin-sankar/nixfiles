#!/usr/bin/env python3

import os
import subprocess
import tempfile

LIST_FILE = os.path.expanduser("~/.resticinclude")
TEMP_OUTPUT = tempfile.NamedTemporaryFile(delete=False)
TEMP_TOTAL = tempfile.NamedTemporaryFile(delete=False)

def path_size(path):
    """Calculate size of path."""
    try:
        if os.path.isdir(path):
            result = subprocess.run(['du', '-sb', path], capture_output=True, text=True, check=True)
            return int(result.stdout.split()[0])
        elif os.path.isfile(path):
            return os.path.getsize(path)
        else:
            return None
    except Exception:
        return None

def analyze_sizes():
    """Analyze paths in include file."""
    total_size = 0
    with open(LIST_FILE, 'r') as file, open(TEMP_OUTPUT.name, 'w') as output:
        for raw_pattern in file:
            pattern = raw_pattern.strip()
            if not pattern or pattern.startswith('#'):
                continue  # Skip empty/commented lines

            expanded = subprocess.run(['bash', '-c', f"echo {pattern}"], capture_output=True, text=True).stdout.splitlines()
            matched = [p for p in expanded if os.path.exists(p)]

            if not matched:
                output.write(f"N/A\t{pattern} (No Matches)\n")
                continue

            for path in matched:
                size = path_size(path)
                if size is not None:
                    total_size += size
                    human_size = subprocess.run(['numfmt', '--to=si', '--suffix=B', str(size)], capture_output=True, text=True).stdout.strip()
                    output.write(f"{human_size}\t{path}\n")
                else:
                    output.write(f"N/A\t{path} (Unreadable/Skipped)\n")

    with open(TEMP_TOTAL.name, 'w') as total_file:
        total_file.write(str(total_size))

def read_summary():
    """Display size summary."""
    with open(TEMP_OUTPUT.name, 'r') as output, open(TEMP_TOTAL.name, 'r') as total_file:
        for line in output:
            size, path = line.strip().split('\t')
            if size == "N/A":
                print(f"✖ {path}")
            else:
                print(f"{size} {path}")
        print("--------------------------------------------------")
        total_human = subprocess.run(['numfmt', '--to=si', '--suffix=B', str(total_file.read().strip())], capture_output=True, text=True).stdout.strip()
        print(f"TOTAL COMBINED: {total_human}")

if __name__ == "__main__":
    if not os.path.exists(LIST_FILE):
        print(f"⚠ Configuration file '{LIST_FILE}' not found.")
        print("Would you like to create a template file now? (y/n): ", end="")
        if input().lower() == 'y':
            with open(LIST_FILE, 'w') as tmpl:
                tmpl.writelines(["# Add files, directories, or patterns to back up\n", "~/Documents\n", "~/.config\n", "~/example/*.pdf\n"])
            print(f"✔ Created {LIST_FILE} with example paths.")
        else:
            exit(1)

    analyze_sizes()
    read_summary()